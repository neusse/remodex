{
  "schema": "universal-pet-v1",
  "name": "Relay",
  "slug": "relay",
  "description": "A tiny animated relay companion for Remodex Host.",
  "spritesheet": {
    "file": "spritesheet.webp",
    "width": 1536,
    "height": 1872,
    "columns": 8,
    "rows": 9,
    "cellWidth": 192,
    "cellHeight": 208
  },
  "animations": {
    "idle": { "row": 0, "frames": 6, "fps": 5, "loop": true },
    "running-right": { "row": 1, "frames": 8, "fps": 10, "loop": true },
    "running-left": { "row": 2, "frames": 8, "fps": 10, "loop": true },
    "waving": { "row": 3, "frames": 4, "fps": 5, "loop": true },
    "jumping": { "row": 4, "frames": 5, "fps": 8, "loop": true },
    "failed": { "row": 5, "frames": 8, "fps": 7, "loop": true },
    "waiting": { "row": 6, "frames": 6, "fps": 4, "loop": true },
    "running": { "row": 7, "frames": 6, "fps": 9, "loop": true },
    "review": { "row": 8, "frames": 6, "fps": 5, "loop": true }
  },
  "stateMap": {
    "default": "idle",
    "stopped": "waiting",
    "starting": "jumping",
    "relay_running": "idle",
    "local_ready": "idle",
    "remote_placeholder_ready": "review",
    "waiting_for_pairing": "waving",
    "connected": "jumping",
    "warning": "review",
    "error": "failed"
  }
}
