{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Remodex Host",
  "version": "0.2.0",
  "identifier": "com.remodex.host",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run copy-bundled"
  },
  "app": {
    "windows": [
      {
        "title": "Remodex Host",
        "label": "main",
        "width": 480,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "bundled": "bundled"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYwNEE4RjU3OTZERDc1NzMKUldSemRkMldWNDlLWUJSVUhpZHlvWDBSaWlzSURiM3l2dXRBRHhueVlHRURMQXpTaTkrY2xDU2kK",
      "endpoints": [
        "https://github.com/Stivy-01/remodex/releases/download/Remodex-Host-Beta/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
